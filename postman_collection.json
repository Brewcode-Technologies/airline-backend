    {
      "name": "Coupa PunchOut",
      "item": [
        {
          "name": "1. PunchOutSetupRequest (Coupa → us)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is XML', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('xml'));",
                  "pm.test('Contains StartPage URL', () => pm.expect(pm.response.text()).to.include('StartPage'));",
                  "const match = pm.response.text().match(/session=([^&'\"<]+)/);",
                  "if (match) pm.collectionVariables.set('coupaBuyerCookie', decodeURIComponent(match[1]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/coupa/punchout/setup",
            "header": [{ "key": "Content-Type", "value": "text/xml" }],
            "body": {
              "mode": "raw",
